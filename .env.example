# macOS signing & notarization secrets (used by scripts/notarize.sh).
# Copy to `.env` (gitignored) and fill in. NEVER commit real values.

# --- Code signing ---
APPLE_SIGNING_IDENTITY="Developer ID Application: Your Name (TEAMID)"
# For CI: base64-encoded .p12 and its password (local builds can use the login keychain instead)
APPLE_CERTIFICATE=""
APPLE_CERTIFICATE_PASSWORD=""

# --- Notarization: Apple ID method ---
APPLE_ID=""
APPLE_PASSWORD=""        # app-specific password
APPLE_TEAM_ID=""

# --- Notarization: App Store Connect API key method (alternative) ---
# APPLE_API_KEY=""
# APPLE_API_ISSUER=""
# APPLE_API_KEY_PATH=""
