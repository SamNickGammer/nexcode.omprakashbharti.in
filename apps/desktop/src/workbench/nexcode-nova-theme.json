  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#5a6078", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted", "punctuation.definition.string", "string.template"], "settings": { "foreground": "#5be3a0" } },
    { "scope": ["constant.character.escape", "string.regexp"], "settings": { "foreground": "#34e1d5" } },
    { "scope": ["constant.numeric", "constant.language", "constant.character", "keyword.other.unit", "support.constant"], "settings": { "foreground": "#ffb454" } },
    { "scope": ["keyword", "storage.type", "storage.modifier", "keyword.operator.expression"], "settings": { "foreground": "#9d7bff" } },
    { "scope": ["keyword.control", "keyword.control.flow", "keyword.control.import", "keyword.control.conditional", "keyword.operator.new"], "settings": { "foreground": "#ff8fd0" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#56c8d8" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call.generic", "meta.function-call"], "settings": { "foreground": "#4ac0ff" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class", "entity.name.type.class"], "settings": { "foreground": "#34e1d5" } },
    { "scope": ["support.type.primitive", "storage.type.primitive"], "settings": { "foreground": "#56c8d8" } },
    { "scope": ["variable", "meta.definition.variable.name", "variable.other.readwrite", "variable.other"], "settings": { "foreground": "#e6e8f2" } },
    { "scope": ["variable.other.constant", "variable.other.enummember"], "settings": { "foreground": "#ffb454" } },
    { "scope": ["variable.other.property", "support.variable.property", "meta.object-literal.key", "variable.other.object.property"], "settings": { "foreground": "#8fb8ff" } },
    { "scope": ["variable.parameter", "meta.parameter"], "settings": { "foreground": "#c9a8ff" } },
    { "scope": ["variable.language", "variable.language.this"], "settings": { "foreground": "#ff8fd0", "fontStyle": "italic" } },
    { "scope": ["entity.name.tag", "punctuation.definition.tag"], "settings": { "foreground": "#ff8fd0" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#ffb454", "fontStyle": "italic" } },
    { "scope": ["support.type.property-name.css", "support.type.property-name"], "settings": { "foreground": "#4ac0ff" } },
    { "scope": ["markup.heading", "entity.name.section", "markup.heading entity.name"], "settings": { "foreground": "#5b8cff", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "foreground": "#ffb454", "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "foreground": "#9d7bff", "fontStyle": "italic" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code", "markup.raw"], "settings": { "foreground": "#5be3a0" } },
    { "scope": ["markup.underline.link", "markup.link"], "settings": { "foreground": "#34e1d5" } },
    { "scope": ["punctuation", "meta.brace", "punctuation.separator", "punctuation.terminator"], "settings": { "foreground": "#a3a8c2" } },
    { "scope": ["invalid", "invalid.illegal"], "settings": { "foreground": "#ff5d7e" } }
  ]
}
