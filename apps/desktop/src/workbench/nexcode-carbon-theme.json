    "sideBar.background": "#0b0b0e",
    "sideBar.foreground": "#bcbcc4",
    "sideBar.border": "#161619",
    "sideBarTitle.foreground": "#7a7a82",
    "sideBarSectionHeader.background": "#0b0b0e",
    "sideBarSectionHeader.foreground": "#8a8a92",
    "sideBarSectionHeader.border": "#161619",

    "list.activeSelectionBackground": "#172238",
    "list.activeSelectionForeground": "#ffffff",
    "list.inactiveSelectionBackground": "#13131a",
    "list.hoverBackground": "#121218",
    "list.focusBackground": "#172238",
    "list.highlightForeground": "#4da6ff",
    "tree.indentGuidesStroke": "#23232a",

    "editorGroup.border": "#161619",
    "editorGroupHeader.tabsBackground": "#08080a",
