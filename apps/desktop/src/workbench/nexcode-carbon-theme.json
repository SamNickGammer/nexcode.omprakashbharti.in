    "tab.activeForeground": "#ffffff",
    "tab.inactiveBackground": "#08080a",
    "tab.inactiveForeground": "#74747c",
    "tab.border": "#161619",
    "tab.activeBorder": "#0a0a0c",
    "tab.activeBorderTop": "#4da6ff",
    "tab.hoverBackground": "#0e0e12",
    "tab.unfocusedActiveBorderTop": "#33333a",

    "panel.background": "#0a0a0c",
    "panel.border": "#161619",
    "panelTitle.activeForeground": "#e3e3e6",
    "panelTitle.activeBorder": "#4da6ff",
    "panelTitle.inactiveForeground": "#6a6a72",

    "statusBar.background": "#08080a",
    "statusBar.foreground": "#9a9aa2",
    "statusBar.border": "#161619",
    "statusBar.noFolderBackground": "#08080a",
    "statusBar.debuggingBackground": "#4da6ff",
    "statusBar.debuggingForeground": "#04060a",
    "statusBarItem.remoteBackground": "#4da6ff",
    "statusBarItem.remoteForeground": "#04060a",
    "statusBarItem.hoverBackground": "#ffffff14",

    "button.background": "#4da6ff",
