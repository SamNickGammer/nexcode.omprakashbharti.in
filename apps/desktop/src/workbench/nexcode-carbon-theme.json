    "button.secondaryForeground": "#e3e3e6",
    "button.secondaryHoverBackground": "#26262e",

    "input.background": "#101014",
    "input.foreground": "#e3e3e6",
    "input.border": "#23232a",
    "input.placeholderForeground": "#5a5a62",
    "inputOption.activeBorder": "#4da6ff",
    "inputOption.activeBackground": "#4da6ff33",
    "dropdown.background": "#101014",
    "dropdown.border": "#23232a",

    "badge.background": "#1c2a44",
    "badge.foreground": "#9cc7ff",
    "progressBar.background": "#4da6ff",

    "quickInput.background": "#0c0c10",
    "quickInputList.focusBackground": "#172238",
    "pickerGroup.foreground": "#4da6ff",
    "pickerGroup.border": "#1f1f25",

    "scrollbar.shadow": "#00000000",
    "scrollbarSlider.background": "#ffffff14",
    "scrollbarSlider.hoverBackground": "#ffffff24",
    "scrollbarSlider.activeBackground": "#ffffff33",

    "terminal.background": "#0a0a0c",
    "terminal.foreground": "#cfcfd6",
    "terminalCursor.foreground": "#4da6ff",
    "terminal.ansiBlue": "#4da6ff",
    "terminal.ansiBrightBlue": "#6cb6ff",
    "terminal.ansiGreen": "#46b97a",
    "terminal.ansiCyan": "#34e1d5",
    "terminal.ansiMagenta": "#b58bff",

    "panelSectionHeader.background": "#0a0a0c",
    "menu.background": "#0c0c10",
    "menu.border": "#1f1f25",
    "menu.selectionBackground": "#172238",
    "notificationCenterHeader.background": "#0c0c10",
    "notifications.background": "#0c0c10",
    "notifications.border": "#1f1f25",

    "gitDecoration.modifiedResourceForeground": "#e5a663",
    "gitDecoration.untrackedResourceForeground": "#46b97a",
    "gitDecoration.deletedResourceForeground": "#ff6b6b",
    "gitDecoration.ignoredResourceForeground": "#4a4a52",

    "textLink.foreground": "#4da6ff",
    "textLink.activeForeground": "#6cb6ff",
    "breadcrumb.foreground": "#7a7a82",
    "breadcrumb.focusForeground": "#e3e3e6",
    "minimap.selectionHighlight": "#4da6ff"
  },
  "tokenColors": [
    { "scope": ["comment", "punctuation.definition.comment"], "settings": { "foreground": "#5c5c66", "fontStyle": "italic" } },
    { "scope": ["string", "string.quoted", "punctuation.definition.string"], "settings": { "foreground": "#87d96c" } },
    { "scope": ["constant.numeric", "constant.language", "constant.character", "keyword.other.unit"], "settings": { "foreground": "#e5a663" } },
    { "scope": ["keyword", "storage.type", "storage.modifier"], "settings": { "foreground": "#6ea8fe" } },
    { "scope": ["keyword.control", "keyword.operator.new", "keyword.control.flow"], "settings": { "foreground": "#b58bff" } },
    { "scope": ["keyword.operator"], "settings": { "foreground": "#9aa5b1" } },
    { "scope": ["entity.name.function", "support.function", "meta.function-call.generic"], "settings": { "foreground": "#7cc7ff" } },
    { "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class", "entity.other.inherited-class"], "settings": { "foreground": "#34e1d5" } },
    { "scope": ["variable", "meta.definition.variable.name", "variable.other.readwrite"], "settings": { "foreground": "#e3e3e6" } },
    { "scope": ["variable.other.property", "support.variable.property", "meta.object-literal.key"], "settings": { "foreground": "#b6c2d9" } },
    { "scope": ["variable.parameter"], "settings": { "foreground": "#cdb9ff" } },
    { "scope": ["entity.name.tag", "punctuation.definition.tag"], "settings": { "foreground": "#6ea8fe" } },
    { "scope": ["entity.other.attribute-name"], "settings": { "foreground": "#e5a663" } },
    { "scope": ["markup.heading", "entity.name.section"], "settings": { "foreground": "#6ea8fe", "fontStyle": "bold" } },
    { "scope": ["markup.bold"], "settings": { "fontStyle": "bold" } },
    { "scope": ["markup.italic"], "settings": { "fontStyle": "italic" } },
    { "scope": ["markup.inline.raw", "markup.fenced_code"], "settings": { "foreground": "#87d96c" } },
    { "scope": ["invalid", "invalid.illegal"], "settings": { "foreground": "#ff6b6b" } }
  ]
}
